# MySQL
MYSQL_DATABASE=crm_db
MYSQL_USER=crm_user
MYSQL_PASSWORD=change_me_strong_mysql_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# Backend datasource
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/crm_db
SPRING_DATASOURCE_USERNAME=crm_user
SPRING_DATASOURCE_PASSWORD=change_me_strong_mysql_password

# Backend app
SERVER_PORT=8081
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRATION_MS=3600000

# Public ports
FRONTEND_PORT=5173
BACKEND_PORT=8081
MYSQL_PORT=3307

# Frontend
VITE_API_BASE_URL=http://localhost:8081/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Email
# Local email testing
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@tadamun.local
MAIL_FROM_NAME=Tadamun
MAIL_REPLY_TO=support@tadamun.local
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_CONNECTION_TIMEOUT_MS=5000
MAIL_TIMEOUT_MS=5000
MAIL_WRITE_TIMEOUT_MS=5000
APP_EMAIL_ENABLED=true
MANAGEMENT_HEALTH_MAIL_ENABLED=false
# Attachments
ATTACHMENT_STORAGE_PATH=/data/attachments
ATTACHMENT_MAX_FILE_SIZE=10MB
ATTACHMENT_MAX_REQUEST_SIZE=11MB
ATTACHMENT_MAX_SIZE_BYTES=10485760
ATTACHMENT_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg,text/plain,text/csv,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
# App URLs
APP_FRONTEND_BASE_URL=http://localhost:5173