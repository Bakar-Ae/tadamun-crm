# MySQL
MYSQL_DATABASE=crm_db
MYSQL_USER=crm_user
MYSQL_PASSWORD=change_me_strong_mysql_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# Backend datasource
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/crm_db
SPRING_DATASOURCE_USERNAME=crm_user
SPRING_DATASOURCE_PASSWORD=change_me_strong_mysql_password

# Backend app
SERVER_PORT=8081
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRATION_MS=3600000

# Public ports
FRONTEND_PORT=5173
BACKEND_PORT=8081
MYSQL_PORT=3307

# Frontend
VITE_API_BASE_URL=http://localhost:8081/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173